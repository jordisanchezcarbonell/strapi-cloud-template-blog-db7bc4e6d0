{
  "kind": "collectionType",
  "collectionName": "short_video_drafts",
  "info": {
    "singularName": "short-video-draft",
    "pluralName": "short-video-drafts",
    "displayName": "Short Video Draft",
    "description": "Reviewable video drafts generated by MenteVolatil Short Video Bot"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "platform": {
      "type": "enumeration",
      "enum": ["tiktok", "reel", "both"],
      "required": true,
      "default": "both"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "idea",
        "scripted",
        "render_pending",
        "rendered",
        "approved",
        "published",
        "failed"
      ],
      "required": true,
      "default": "scripted"
    },
    "topic": { "type": "string", "required": true },
    "hook": { "type": "text", "required": true },
    "script": { "type": "text", "required": true },
    "caption": { "type": "text", "required": true },
    "hashtags": { "type": "json", "required": true },
    "visualPlan": { "type": "json", "required": true },
    "subtitleLines": { "type": "json", "required": true },
    "voiceoverText": { "type": "text" },
    "audioUrl": { "type": "string" },
    "videoUrl": { "type": "string" },
    "thumbnailUrl": { "type": "string" },
    "sourceUrls": { "type": "json", "required": true },
    "scheduledAt": { "type": "datetime" },
    "socialPublishedAt": { "type": "datetime" },
    "hash": { "type": "string", "required": true, "unique": true },
    "rawPayload": { "type": "json" }
  }
}
